APP_NAME=CargoNest API
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_ORIGIN=https://your-frontend-domain.vercel.app
FRONTEND_ORIGINS=https://your-frontend-domain.vercel.app
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=replace-me
SUPABASE_SERVICE_ROLE_KEY=replace-me
SUPABASE_STORAGE_BUCKET=cargonest-attachments
SUPABASE_STORAGE_FOLDER=forms
DATABASE_URL=postgresql+psycopg://postgres.your-project-ref:replace-me@aws-1-your-region.pooler.supabase.com:5432/postgres?sslmode=require
AUTO_CREATE_TABLES=false
LOG_LEVEL=INFO
FRONTEND_ERROR_REPORTING_ENABLED=true
SESSION_DURATION_HOURS=24
SESSION_SECRET_KEY=replace-me-with-a-long-random-secret
SESSION_COOKIE_NAME=cargonest_session
CSRF_COOKIE_NAME=cargonest_csrf
BOOTSTRAP_ADMIN_ENABLED=false
BOOTSTRAP_ADMIN_USERNAME=replace-me
BOOTSTRAP_ADMIN_EMAIL=replace-me@example.com
BOOTSTRAP_ADMIN_PASSWORD=replace-me
