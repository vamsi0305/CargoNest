APP_NAME=CargoNest API
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
FRONTEND_ORIGIN=http://localhost:5173
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=cargonest-attachments
SUPABASE_STORAGE_FOLDER=forms
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/cargonest
AUTO_CREATE_TABLES=true
LOG_LEVEL=INFO
FRONTEND_ERROR_REPORTING_ENABLED=true
SESSION_DURATION_HOURS=24
SESSION_SECRET_KEY=replace-me-with-a-long-random-secret
SESSION_COOKIE_NAME=cargonest_session
CSRF_COOKIE_NAME=cargonest_csrf
BOOTSTRAP_ADMIN_ENABLED=false
BOOTSTRAP_ADMIN_USERNAME=replace-me-admin
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=replace-me-secure-password
